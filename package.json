{
	"name": "orenlyonsarchive",
	"version": "0.0.1",
	"description": "orenlyonsarchive web site using the Eleventy site generator develop by Adam Dj Brett.",
	"type": "module",
	"scripts": {
		"build": "cross-env NODE_ENV=production npx @11ty/eleventy",
		"build-nocolor": "cross-env NODE_DISABLE_COLORS=1 npx @11ty/eleventy",
		"build-ghpages": "npx @11ty/eleventy --pathprefix=/orenlyonsarchive/",
		"start": "npx @11ty/eleventy --serve --quiet",
		"start-ghpages": "npx @11ty/eleventy --pathprefix=/orenlyonsarchive/ --serve --quiet",
		"debug": "cross-env DEBUG=Eleventy* npx @11ty/eleventy",
		"debugstart": "cross-env DEBUG=Eleventy* npx @11ty/eleventy --serve --quiet",
		"benchmark": "cross-env DEBUG=Eleventy:Benchmark* npx @11ty/eleventy"
	},
	"repository": {
		"type": "git",
		"url": "git://github.com/adamdjbrett/orenlyonsarchive.git"
	},
	"author": "Adam Dj Brett <info@adamdjbrett.com> (https://adamdjbrett.com/)",
	"license": "MIT",
	"engines": {
		"node": ">=22"
	},
	"devDependencies": {
		"@11ty/eleventy": "^3.1.2",
		"@11ty/eleventy-navigation": "^1.0.4",
		"@11ty/eleventy-plugin-rss": "^2.0.4",
		"@11ty/eleventy-plugin-syntaxhighlight": "^5.0.1",
		"@minify-html/node": "^0.18.1",
		"clean-css": "^5.3.3",
		"cross-env": "^7.0.3",
		"luxon": "^3.6.1",
		"markdown-it": "^14.1.0",
		"prismjs": "^1.30.0",
		"purgecss": "^7.0.0",
		"zod": "^3.25.67",
		"zod-validation-error": "^3.5.2"
	},
	"dependencies": {
		"@11ty/font-awesome": "^1.0.0",
		"@minify-html/node-darwin-arm64": "^0.18.1",
		"eleventy-plugin-youtube-embed": "^1.13.1",
		"lite-youtube-embed": "^0.3.4",
		"markdown-it": "^14.1.0"
	},
	"main": "eleventy.config.js",
	"keywords": [],
	"bugs": {
		"url": "https://github.com/adamdjbrett/orenlyonsarchive/issues"
	},
	"homepage": "https://github.com/adamdjbrett/orenlyonsarchive#readme"
}
